# --- AWS Bedrock ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional when using temporary credentials:
# AWS_SESSION_TOKEN=

# Main pipeline VLM when VLM_PROVIDER=bedrock (tables, layout classification, etc.)
# NOTE: the quite_change quarterly classifier uses Sonnet — set this to
#   us.anthropic.claude-sonnet-4-6   when running build/run_cohort_bedrock.py
BEDROCK_MODEL_ID=us.anthropic.claude-opus-4-6-v1
# Force the Bedrock path for LLM calls (Anthropic key is out of credits):
USE_BEDROCK=true

EDINET_API_KEY=

# --- TempestAI Finance API (staging) ---
TEMPEST_API_URL=https://d3vxxnzct48oog.cloudfront.net
TEMPEST_API_KEY=

# --- Anthropic direct API (OPTIONAL; leave blank to force Bedrock) ---
# If set, some scripts prefer it over Bedrock. Currently out of credits.
ANTHROPIC_API_KEY=

# --- Optional / legacy (not required by the quarterly pipeline) ---
TAVILY_API_KEY=
SERP_API_KEY=