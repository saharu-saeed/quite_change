# --- Secrets / env ---
.env
.env.*
!.env.example

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# --- Virtual environments ---
venv/
.venv/
env/
ENV/

# --- IDE / editor ---
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# --- Project: heavy generated / cached data ---
# The Tempest data cache (~1.2GB) is regenerated by the ingestion pipeline,
# not committed to git.
data/

# Agent outputs, reports, backtest artifacts (~58MB). Regenerated per run.
outputs/*
# ...but keep the two reference docs the README links to.
!outputs/AGENT_REPORT.md
!outputs/CLIENT_DEMO.md

# --- Logs and one-off artifacts ---
*.log
*.err
